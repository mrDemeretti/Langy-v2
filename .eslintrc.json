{
    "env": {
        "browser": true,
        "es2021": true
    },
    "globals": {
        "LangyConfig": "readonly",
        "LangyLogger": "readonly",
        "LangyState": "writable",
        "LangyApp": "readonly",
        "LangyDB": "readonly",
        "LangyI18n": "readonly",
        "LangyIcons": "readonly",
        "LangyCurriculum": "readonly",
        "LangyVocabBank": "readonly",
        "LangyGrammarBank": "readonly",
        "ExerciseGenerator": "readonly",
        "Router": "readonly",
        "Anim": "readonly",
        "AudioUtils": "readonly",
        "ScreenState": "writable",
        "DeepTutor": "readonly",
        "TalkEngine": "readonly",
        "DailySpeaking": "readonly",
        "CoachIntel": "readonly",
        "WidgetRenderer": "readonly",
        "LangyAI": "readonly",
        "escapeHTML": "readonly",
        "sanitizeHTML": "readonly",
        "getLocalDateString": "readonly",
        "dateDiffDays": "readonly",
        "debounce": "readonly",
        "clamp": "readonly",
        "randomId": "readonly",
        "i18n": "readonly",
        "getState": "readonly",
        "setState": "readonly",
        "recordSession": "readonly",
        "getStreakReward": "readonly",
        "checkLevelUp": "readonly",
        "showLevelUpOverlay": "readonly",
        "updateEventProgress": "readonly",
        "getDefaultState": "readonly",
        "getStateSnapshot": "readonly",
        "loadFromSnapshot": "readonly",
        "resetState": "readonly",
        "toggleDarkMode": "readonly",
        "showStreakOverlay": "readonly",
        "pdfjsLib": "readonly",
        "mammoth": "readonly",
        "JSZip": "readonly",
        "firebase": "readonly",
        "showOnboardingTooltips": "readonly",
        "LangyWidgets": "readonly",
        "DailySpeaking": "readonly",
        "CoachIntel": "readonly",
        "LangyMetrics": "readonly",
        "module": "readonly"
    },
    "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "script"
    },
    "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^(render|show|hide|init|Langy|Router|Anim|Audio|Screen|Deep|Talk|Exercise|Widget|escape|sanitize|get|set|record|check|update|load|reset|toggle|debounce|clamp|random|i18n|dateDiff)" }],
        "no-undef": "error",
        "no-redeclare": ["error", { "builtinGlobals": false }],
        "no-duplicate-case": "error",
        "no-empty": "warn",
        "no-extra-semi": "warn",
        "no-unreachable": "warn",
        "eqeqeq": ["warn", "smart"],
        "no-eval": "error",
        "no-implied-eval": "error",
        "no-new-func": "error",
        "prefer-const": "warn",
        "no-var": "warn",
        "no-console": "off"
    }
}
