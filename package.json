{
  "name": "langy",
  "private": true,
  "version": "2.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\" \"styles/**/*.css\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "npm run lint && npm run test"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.2.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
